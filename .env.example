# Copy to .env.local for development. See docs/ENVIRONMENT.md for details.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Stripe (test keys in dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ONE_TIME_PDF=
STRIPE_PRICE_MONTHLY_SUB=
# Required when using subscription Checkout (/api/stripe/checkout kind=subscription):
STRIPE_PRICE_TRIAL_ONE_TIME=price_xxx

# AI (required for AI routes and actions)
OPENAI_API_KEY=
# OPENAI_MODEL=

# Public URL for redirects (local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: server-side fallback when NEXT_PUBLIC_APP_URL is absent (same shape, no trailing slash)
# APP_URL=

# Transactional email (Resend). Omit RESEND_API_KEY or EMAIL_FROM to disable sends; a warning logs once on first outbound attempt.
RESEND_API_KEY=
EMAIL_FROM=

# Admin analytics: exact email allowed to operate /admin after normal sign-in. Omit = nobody is the admin-only operator match.
ADMIN_ANALYTICS_EMAIL=

# Optional: PDF on Docker / custom Chromium
# PUPPETEER_EXECUTABLE_PATH=
# Force packaged Chromium binary (deploy-specific)
# PDF_USE_PACKAGED_CHROMIUM=1
